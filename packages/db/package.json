{
	"name": "@selimsolutions/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"db:push": "prisma db push",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"postinstall": "prisma generate",
		"db:studio": "prisma studio",
		"db:start": "docker compose up -d",
		"db:watch": "docker compose up",
		"db:stop": "docker compose stop",
		"db:down": "docker compose down",
		"db:push:prod": "cross-env NODE_ENV=production prisma db push",
		"db:migrate:prod": "cross-env NODE_ENV=production prisma migrate deploy",
		"db:studio:prod": "cross-env NODE_ENV=production prisma studio"
	},
	"dependencies": {
		"@prisma/adapter-mariadb": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@selimsolutions/env": "*",
		"dotenv": "^17.2.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@selimsolutions/config": "*",
		"cross-env": "^7.0.3",
		"prisma": "^7.8.0",
		"typescript": "^6"
	}
}
